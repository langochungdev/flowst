{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Flowst - Minimal Pomodoro Timer",
    "version": "0.15.0",
    "identifier": "com.langochungdev.flowst",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Flowst - Minimal Pomodoro Timer",
                "width": 300,
                "height": 320,
                "decorations": false,
                "transparent": true,
                "resizable": false,
                "alwaysOnTop": true,
                "visible": false,
                "skipTaskbar": true,
                "url": "index.html"
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "publisher": "Hung La Ngoc",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}