{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flowst",
  "version": "0.3.0",
  "identifier": "com.langochungdev.flowst",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Flowst",
        "width": 300,
        "height": 360,
        "minWidth": 300,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "url": "index.html"
      },
      {
        "label": "mini",
        "title": "Flowst Mini",
        "width": 150,
        "height": 110,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "url": "index.html"
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 300,
        "height": 420,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
